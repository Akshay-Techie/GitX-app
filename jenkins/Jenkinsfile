// ════════════════════════════════════════════════
// GitX — Jenkinsfile
// CI Pipeline: Build → Scan → Push to AWS ECR
// Author: Akshay-Techie
// All values fetched from Jenkins Credentials
// Zero hardcoded secrets or IDs
// ════════════════════════════════════════════════

pipeline {

    // Run on any available Jenkins agent
    agent any

    // ── Environment Variables ──────────────────
    // Only non-sensitive values here
    environment {
        // ECR Repository name
        ECR_REPO  = "gitx-app"

        // Image tag uses Jenkins build number
        // e.g. build-1, build-2, build-3
        IMAGE_TAG = "build-${BUILD_NUMBER}"
    }

    stages {

        // ── Stage 1: Checkout ──────────────────
        stage('Checkout') {
            steps {
                echo '📥 Checking out source code from GitHub...'
                // Jenkins pulls code from GitHub
                // repo configured in job settings
                checkout scm
            }
        }

        // ── Stage 2: Build Docker Image ────────
        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                // Fetch AWS Account ID and Region
                // from Jenkins credentials store
                withCredentials([
                    string(credentialsId: 'aws-account-id',
                           variable: 'AWS_ACCOUNT_ID'),
                    string(credentialsId: 'aws-region',
                           variable: 'AWS_REGION')
                ]) {
                    sh """
                        # Build full ECR image URL dynamically
                        ECR_URL=\$AWS_ACCOUNT_ID.dkr.ecr.\$AWS_REGION.amazonaws.com
                        IMAGE=\$ECR_URL/${ECR_REPO}

                        # Build Docker image from app/ folder
                        docker build -t \$IMAGE:${IMAGE_TAG} ./app

                        # Also tag as latest
                        docker tag \$IMAGE:${IMAGE_TAG} \$IMAGE:latest

                        echo "✅ Built: \$IMAGE:${IMAGE_TAG}"
                    """
                }
            }
        }

        // ── Stage 3: Security Scan (Trivy) ─────
        stage('Security Scan') {
            steps {
                echo '🔒 Running Trivy security scan...'
                withCredentials([
                    string(credentialsId: 'aws-account-id',
                           variable: 'AWS_ACCOUNT_ID'),
                    string(credentialsId: 'aws-region',
                           variable: 'AWS_REGION')
                ]) {
                    sh """
                        ECR_URL=\$AWS_ACCOUNT_ID.dkr.ecr.\$AWS_REGION.amazonaws.com
                        IMAGE=\$ECR_URL/${ECR_REPO}

                        # Install Trivy if not already installed
                        which trivy || (
                            wget -qO- https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh \
                            | sh -s -- -b /usr/local/bin
                        )

                        # Scan image for HIGH and CRITICAL vulnerabilities
                        # exit-code 0 = warn but do not fail the build
                        # exit-code 1 = fail build if vulnerability found
                        trivy image \
                            --exit-code 0 \
                            --severity HIGH,CRITICAL \
                            --no-progress \
                            \$IMAGE:${IMAGE_TAG}

                        echo "✅ Security scan complete"
                    """
                }
            }
        }

        // ── Stage 4: Login to AWS ECR ──────────
        stage('Login to ECR') {
            steps {
                echo '🔐 Logging in to AWS ECR...'
                // Fetch all AWS credentials
                // from Jenkins credentials store
                withCredentials([
                    string(credentialsId: 'aws-account-id',
                           variable: 'AWS_ACCOUNT_ID'),
                    string(credentialsId: 'aws-region',
                           variable: 'AWS_REGION'),
                    string(credentialsId: 'aws-access-key-id',
                           variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key',
                           variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh """
                        # Configure AWS CLI with credentials
                        aws configure set aws_access_key_id \$AWS_ACCESS_KEY_ID
                        aws configure set aws_secret_access_key \$AWS_SECRET_ACCESS_KEY
                        aws configure set default.region \$AWS_REGION

                        # Login Docker to ECR using AWS CLI token
                        aws ecr get-login-password \
                            --region \$AWS_REGION | \
                        docker login \
                            --username AWS \
                            --password-stdin \
                            \$AWS_ACCOUNT_ID.dkr.ecr.\$AWS_REGION.amazonaws.com

                        echo "✅ Logged in to ECR successfully"
                    """
                }
            }
        }

        // ── Stage 5: Create ECR Repo if needed ─
        stage('Create ECR Repository') {
            steps {
                echo '📦 Ensuring ECR repository exists...'
                withCredentials([
                    string(credentialsId: 'aws-account-id',
                           variable: 'AWS_ACCOUNT_ID'),
                    string(credentialsId: 'aws-region',
                           variable: 'AWS_REGION'),
                    string(credentialsId: 'aws-access-key-id',
                           variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key',
                           variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh """
                        aws configure set aws_access_key_id \$AWS_ACCESS_KEY_ID
                        aws configure set aws_secret_access_key \$AWS_SECRET_ACCESS_KEY
                        aws configure set default.region \$AWS_REGION

                        # Create ECR repo only if it does not exist
                        aws ecr describe-repositories \
                            --repository-names ${ECR_REPO} \
                            --region \$AWS_REGION \
                        || \
                        aws ecr create-repository \
                            --repository-name ${ECR_REPO} \
                            --region \$AWS_REGION

                        echo "✅ ECR repository ready: ${ECR_REPO}"
                    """
                }
            }
        }

        // ── Stage 6: Push to ECR ───────────────
        stage('Push to ECR') {
            steps {
                echo '⬆️ Pushing image to AWS ECR...'
                withCredentials([
                    string(credentialsId: 'aws-account-id',
                           variable: 'AWS_ACCOUNT_ID'),
                    string(credentialsId: 'aws-region',
                           variable: 'AWS_REGION')
                ]) {
                    sh """
                        ECR_URL=\$AWS_ACCOUNT_ID.dkr.ecr.\$AWS_REGION.amazonaws.com
                        IMAGE=\$ECR_URL/${ECR_REPO}

                        # Push build tag
                        docker push \$IMAGE:${IMAGE_TAG}

                        # Push latest tag
                        docker push \$IMAGE:latest

                        echo "✅ Pushed: \$IMAGE:${IMAGE_TAG}"
                        echo "✅ Pushed: \$IMAGE:latest"
                    """
                }
            }
        }

        // ── Stage 7: Cleanup ───────────────────
        stage('Cleanup') {
            steps {
                echo '🧹 Cleaning up local Docker images...'
                withCredentials([
                    string(credentialsId: 'aws-account-id',
                           variable: 'AWS_ACCOUNT_ID'),
                    string(credentialsId: 'aws-region',
                           variable: 'AWS_REGION')
                ]) {
                    sh """
                        ECR_URL=\$AWS_ACCOUNT_ID.dkr.ecr.\$AWS_REGION.amazonaws.com
                        IMAGE=\$ECR_URL/${ECR_REPO}

                        # Remove local images to free disk space
                        docker rmi \$IMAGE:${IMAGE_TAG} || true
                        docker rmi \$IMAGE:latest || true

                        echo "✅ Local images cleaned up"
                    """
                }
            }
        }
    }

    // ── Post Actions ───────────────────────────
    post {
        success {
            echo '✅ Pipeline completed successfully!'
            echo "🐳 Image pushed to ECR with tag: build-${BUILD_NUMBER}"
        }
        failure {
            echo '❌ Pipeline failed! Check the logs above.'
        }
        always {
            echo '🔄 Pipeline finished — cleaning workspace'
            cleanWs()
        }
    }
}